{
  "name": "darkcontext",
  "version": "0.2.0",
  "description": "Bring-your-own-context layer for LLMs — self-hosted MCP server backed by SQLite + vector search.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robertclapp/darkcontext.git"
  },
  "bugs": "https://github.com/robertclapp/darkcontext/issues",
  "homepage": "https://github.com/robertclapp/darkcontext#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "llm",
    "memory",
    "context",
    "sqlite",
    "vector-search",
    "embeddings",
    "claude",
    "self-hosted"
  ],
  "bin": {
    "dcx": "dist/cli/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/cli/index.ts",
    "dcx": "tsx src/cli/index.ts",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"evals/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.all.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "eval": "npm run eval:retrieval && npm run eval:security",
    "eval:retrieval": "tsx evals/retrieval/run.ts",
    "eval:security": "tsx evals/scope-isolation/run.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.3.0",
    "commander": "^12.1.0",
    "sqlite-vec": "^0.1.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.10",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.5",
    "eslint": "^9.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
